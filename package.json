{
  "name": "openapi-agent",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@openapi-agent/cli' dev",
    "dev:studio": "npm run dev --workspace=packages/studio",
    "build": "bun run --filter '*' build",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tanstack/react-hotkeys": "^0.10.0"
  }
}
