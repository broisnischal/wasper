{
  "name": "wasper-cli",
  "version": "0.3.2",
  "description": "Host an MCP server + API proxy from any OpenAPI spec. Like Drizzle Studio, but for APIs.",
  "type": "module",
  "homepage": "https://wasper.site",
  "bin": {
    "wasper": "./bin/wasper.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --hot cli.ts",
    "build": "bun build ./cli.ts ./index.ts --outdir=dist --target=bun",
    "start": "bun dist/cli.js",
    "typecheck": "tsc --noEmit",
    "build:bin": "bun scripts/build-binaries.ts",
    "prepublishOnly": "bun run build && chmod +x bin/wasper.js dist/cli.js"
  },
  "keywords": [
    "wasper",
    "mcp",
    "openapi",
    "api",
    "agent",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  },
  "dependencies": {
    "js-yaml": "^4.2.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "bin",
    "dist/cli.js",
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broisnischal/wasper.git"
  },
  "publishConfig": {
    "access": "public"
  }
}